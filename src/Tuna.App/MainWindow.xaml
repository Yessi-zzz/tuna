<Window x:Class="Tuna.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Tuna.App.Localization"
        Title="{Binding [App.Title], Source={x:Static loc:Localizer.Instance}}"
        Icon="Assets/Tuna.ico"
        Height="800" Width="900" MinWidth="720" MinHeight="600"
        Background="{StaticResource B.Window}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- 列定义复用:参数 / 单位 / 安静 / 均衡 / 性能 / 范围 -->
        <Style x:Key="HeadCell" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{StaticResource B.TextDim}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 一行参数模板 -->
        <DataTemplate x:Key="ParamRow">
            <Grid Height="30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="86"/>
                    <ColumnDefinition Width="86"/>
                    <ColumnDefinition Width="86"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding Unit}" VerticalAlignment="Center" Foreground="{StaticResource B.TextDim}"/>
                <TextBlock Grid.Column="2" Text="{Binding Quiet}" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.CurrentMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="Quiet">
                                    <Setter Property="Foreground" Value="{StaticResource B.Accent}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Grid.Column="3" Text="{Binding Balanced}" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.CurrentMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="Balanced">
                                    <Setter Property="Foreground" Value="{StaticResource B.Accent}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Grid.Column="4" Text="{Binding Performance}" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.CurrentMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="Performance">
                                    <Setter Property="Foreground" Value="{StaticResource B.Accent}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Grid.Column="5" Text="{Binding Range}" VerticalAlignment="Center" Foreground="{StaticResource B.TextDim}"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <DockPanel Margin="18">

        <!-- 顶部控制行:机型名 + 刷新 + 语言 -->
        <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,14">
            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                       Text="{Binding MachineName}" Foreground="{StaticResource B.Text}" FontSize="14" FontWeight="SemiBold"/>
            <Button DockPanel.Dock="Right" Command="{Binding ToggleLanguageCommand}"
                    Content="{Binding NextLanguageLabel, Source={x:Static loc:Localizer.Instance}}"
                    Padding="12,5" Margin="8,0,0,0" ToolTip="中文 / English"/>
            <Button DockPanel.Dock="Right" Command="{Binding RefreshCommand}"
                    Content="{Binding [Action.Refresh], Source={x:Static loc:Localizer.Instance}}"
                    Padding="14,5"/>
        </DockPanel>

        <!-- 状态总览卡片:当前模式 + 实时读数 -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding [Mode.Label], Source={x:Static loc:Localizer.Instance}}"
                               Foreground="{StaticResource B.TextDim}" FontSize="12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Ellipse Width="10" Height="10" Fill="{StaticResource B.Accent}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedMode.Display}" FontSize="24" FontWeight="SemiBold"
                                   Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding CpuReadout}" FontFamily="Consolas" FontSize="15"
                               Foreground="{StaticResource B.Cpu}" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding GpuReadout}" FontFamily="Consolas" FontSize="15"
                               Foreground="{StaticResource B.Gpu}" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 选择模式 -->
        <TextBlock DockPanel.Dock="Top" Margin="2,0,0,8"
                   Text="{Binding [Section.Modes], Source={x:Static loc:Localizer.Instance}}"
                   Foreground="{StaticResource B.TextDim}" FontSize="12" FontWeight="SemiBold"/>
        <ListBox DockPanel.Dock="Top" Style="{StaticResource ModeList}" Margin="0,0,0,18"
                 ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode, Mode=TwoWay}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Icon}" FontSize="26" HorizontalAlignment="Center" FontFamily="Segoe UI Emoji"/>
                        <TextBlock Text="{Binding Display}" FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 插拔电自动切档 -->
        <CheckBox DockPanel.Dock="Top" Margin="2,0,0,16" IsChecked="{Binding AutoSwitch, Mode=TwoWay}"
                  Content="{Binding [Auto.Label], Source={x:Static loc:Localizer.Instance}}"/>

        <!-- 底部状态栏 -->
        <Border DockPanel.Dock="Bottom" Margin="2,12,0,0">
            <TextBlock Text="{Binding Status}" Foreground="{StaticResource B.TextDim}" FontSize="12"/>
        </Border>

        <!-- 参数:CPU / GPU 两个分区(整体滚动,无表内滚动) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- 自定义档调节(仅自定义模式;不生效机型显示说明) -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14"
                        Visibility="{Binding IsCustomMode, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{Binding [Section.Custom], Source={x:Static loc:Localizer.Instance}}"
                                   Foreground="{StaticResource B.Accent}" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>

                        <!-- 不生效机型:说明 + 仍要显示按钮 -->
                        <StackPanel Visibility="{Binding NoticeVisible, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding [Custom.Notice], Source={x:Static loc:Localizer.Instance}}"
                                       Foreground="{StaticResource B.TextDim}" TextWrapping="Wrap" LineHeight="19"/>
                            <Button Content="{Binding [Custom.RevealBtn], Source={x:Static loc:Localizer.Instance}}"
                                    Command="{Binding RevealCustomEditorCommand}" HorizontalAlignment="Left" Margin="0,12,0,0" Padding="14,7"/>
                        </StackPanel>

                        <!-- 编辑器(连续=滑块,离散=下拉) -->
                        <StackPanel Visibility="{Binding EditorsVisible, Converter={StaticResource BoolToVis}}">
                            <ItemsControl ItemsSource="{Binding CustomEditors}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="78"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{StaticResource B.Text}" VerticalAlignment="Center"/>
                                            <Slider Grid.Column="1" VerticalAlignment="Center" Margin="8,0"
                                                    Minimum="{Binding Min}" Maximum="{Binding Max}" Value="{Binding Value, Mode=TwoWay}"
                                                    SmallChange="{Binding Step}" LargeChange="{Binding Step}"
                                                    IsSnapToTickEnabled="True" TickFrequency="{Binding Step}"
                                                    Visibility="{Binding IsContinuous, Converter={StaticResource BoolToVis}}"/>
                                            <ComboBox Grid.Column="1" VerticalAlignment="Center" Margin="8,0" HorizontalAlignment="Left" MinWidth="130"
                                                      ItemsSource="{Binding Choices}" SelectedItem="{Binding SelectedChoice, Mode=TwoWay}"
                                                      Visibility="{Binding IsDiscrete, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                                       Foreground="{StaticResource B.Text}" FontWeight="SemiBold">
                                                <Run Text="{Binding ResolvedValue, Mode=OneWay}"/><Run Text=" "/><Run Text="{Binding Unit, Mode=OneWay}"/>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="{Binding [Custom.Apply], Source={x:Static loc:Localizer.Instance}}"
                                        Command="{Binding ApplyCustomCommand}" Padding="20,7"/>
                                <TextBlock Text="{Binding [Custom.ApplyHint], Source={x:Static loc:Localizer.Instance}}"
                                           Foreground="{StaticResource B.TextDim}" FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 显示与显卡(刷新率切换 / 屏幕超频 / 显卡模式) -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14"
                        Visibility="{Binding HasDisplayCard, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{Binding [Section.Display], Source={x:Static loc:Localizer.Instance}}"
                                   Foreground="{StaticResource B.Accent}" FontSize="15" FontWeight="Bold" Margin="0,0,0,10"/>

                        <!-- 刷新率 -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{StaticResource B.Text}"
                                       Text="{Binding [Disp.RefreshRate], Source={x:Static loc:Localizer.Instance}}"/>
                            <ItemsControl Grid.Column="1" ItemsSource="{Binding RefreshRates}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Label}" Margin="0,0,8,0" Padding="16,6"
                                                Command="{Binding DataContext.SetRefreshRateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource B.Accent}"/>
                                                            <Setter Property="Foreground" Value="{StaticResource B.Window}"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <!-- 屏幕超频 -->
                        <Grid Margin="0,0,0,10" Visibility="{Binding SupportsOverdrive, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{StaticResource B.Text}"
                                       Text="{Binding [Disp.Overdrive], Source={x:Static loc:Localizer.Instance}}"/>
                            <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding Overdrive, Mode=TwoWay}"
                                      Foreground="{StaticResource B.TextDim}"
                                      Content="{Binding [Disp.OverdriveHint], Source={x:Static loc:Localizer.Instance}}"/>
                        </Grid>

                        <!-- 显卡模式 / G-Sync(只读) -->
                        <Grid Visibility="{Binding HasGpuInfo, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{StaticResource B.Text}"
                                       Text="{Binding [Disp.GpuMode], Source={x:Static loc:Localizer.Instance}}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding GpuModeLabel}" Foreground="{StaticResource B.Gpu}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Button Content="{Binding [Disp.GpuSwitch], Source={x:Static loc:Localizer.Instance}}"
                                        Command="{Binding ToggleGpuModeCommand}" Margin="12,0,0,0" Padding="12,4"/>
                                <TextBlock Text="{Binding GSyncLabel}" Foreground="{StaticResource B.TextDim}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                                <TextBlock Text="{Binding [Disp.GpuNote], Source={x:Static loc:Localizer.Instance}}"
                                           Foreground="{StaticResource B.TextDim}" FontSize="11" VerticalAlignment="Center" Margin="14,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 系统开关(关 Win 键 / 触控板) -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14"
                        Visibility="{Binding HasSystemToggles, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{Binding [Section.System], Source={x:Static loc:Localizer.Instance}}"
                                   Foreground="{StaticResource B.Accent}" FontSize="15" FontWeight="Bold" Margin="0,0,0,10"/>
                        <CheckBox IsChecked="{Binding WinKeyDisabled, Mode=TwoWay}" Margin="0,0,0,9" Foreground="{StaticResource B.Text}"
                                  Visibility="{Binding SupportsWinKey, Converter={StaticResource BoolToVis}}"
                                  Content="{Binding [Sys.WinKey], Source={x:Static loc:Localizer.Instance}}"/>
                        <CheckBox IsChecked="{Binding TouchpadEnabled, Mode=TwoWay}" Margin="0,0,0,9" Foreground="{StaticResource B.Text}"
                                  Visibility="{Binding SupportsTouchpad, Converter={StaticResource BoolToVis}}"
                                  Content="{Binding [Sys.Touchpad], Source={x:Static loc:Localizer.Instance}}"/>
                        <CheckBox IsChecked="{Binding BatteryConservation, Mode=TwoWay}" Foreground="{StaticResource B.Text}"
                                  Visibility="{Binding SupportsBatteryConservation, Converter={StaticResource BoolToVis}}"
                                  Content="{Binding [Sys.Battery], Source={x:Static loc:Localizer.Instance}}"/>
                    </StackPanel>
                </Border>

                <!-- CPU 分区 -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="CPU" Foreground="{StaticResource B.Accent}" FontSize="15" FontWeight="Bold" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                                <ColumnDefinition Width="86"/>
                                <ColumnDefinition Width="86"/>
                                <ColumnDefinition Width="86"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource HeadCell}" Text="{Binding [Col.Parameter], Source={x:Static loc:Localizer.Instance}}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource HeadCell}" Text="{Binding [Col.Unit], Source={x:Static loc:Localizer.Instance}}"/>
                            <TextBlock Grid.Column="2" Style="{StaticResource HeadCell}" Text="{Binding [Mode.Quiet], Source={x:Static loc:Localizer.Instance}}"/>
                            <TextBlock Grid.Column="3" Style="{StaticResource HeadCell}" Text="{Binding [Mode.Balanced], Source={x:Static loc:Localizer.Instance}}"/>
                            <TextBlock Grid.Column="4" Style="{StaticResource HeadCell}" Text="{Binding [Mode.Performance], Source={x:Static loc:Localizer.Instance}}"/>
                            <TextBlock Grid.Column="5" Style="{StaticResource HeadCell}" Text="{Binding [Col.Range], Source={x:Static loc:Localizer.Instance}}"/>
                        </Grid>
                        <Border Height="1" Background="{StaticResource B.Border}" Margin="0,2,0,4"/>
                        <ItemsControl ItemsSource="{Binding CpuRows}" ItemTemplate="{StaticResource ParamRow}"/>
                    </StackPanel>
                </Border>

                <!-- GPU 分区 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="GPU" Foreground="{StaticResource B.Accent}" FontSize="15" FontWeight="Bold" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                                <ColumnDefinition Width="86"/>
                                <ColumnDefinition Width="86"/>
                                <ColumnDefinition Width="86"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource HeadCell}" Text="{Binding [Col.Parameter], Source={x:Static loc:Localizer.Instance}}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource HeadCell}" Text="{Binding [Col.Unit], Source={x:Static loc:Localizer.Instance}}"/>
                            <TextBlock Grid.Column="2" Style="{StaticResource HeadCell}" Text="{Binding [Mode.Quiet], Source={x:Static loc:Localizer.Instance}}"/>
                            <TextBlock Grid.Column="3" Style="{StaticResource HeadCell}" Text="{Binding [Mode.Balanced], Source={x:Static loc:Localizer.Instance}}"/>
                            <TextBlock Grid.Column="4" Style="{StaticResource HeadCell}" Text="{Binding [Mode.Performance], Source={x:Static loc:Localizer.Instance}}"/>
                            <TextBlock Grid.Column="5" Style="{StaticResource HeadCell}" Text="{Binding [Col.Range], Source={x:Static loc:Localizer.Instance}}"/>
                        </Grid>
                        <Border Height="1" Background="{StaticResource B.Border}" Margin="0,2,0,4"/>
                        <ItemsControl ItemsSource="{Binding GpuRows}" ItemTemplate="{StaticResource ParamRow}"/>
                    </StackPanel>
                </Border>

                <!-- 风扇曲线(当前档,温度→转速) -->
                <Border Style="{StaticResource Card}" Margin="0,14,0,0"
                        Visibility="{Binding HasFanCurves, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{Binding [Section.Fan], Source={x:Static loc:Localizer.Instance}}"
                                   Foreground="{StaticResource B.Accent}" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding FanCurves}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="132"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource B.Text}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding RangeLabel}" Foreground="{StaticResource B.TextDim}" FontSize="11" Margin="0,3,0,0"/>
                                            <TextBlock Text="{Binding TempLabel}" Foreground="{StaticResource B.TextDim}" FontSize="11"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Width="268" Height="68" Background="{StaticResource B.Window}"
                                                BorderBrush="{StaticResource B.Border}" BorderThickness="1" CornerRadius="6">
                                            <Canvas Width="260" Height="60" Margin="4" ClipToBounds="True">
                                                <Polyline Points="{Binding Points}" Stroke="{StaticResource B.Accent}"
                                                          StrokeThickness="2" StrokeLineJoin="Round"/>
                                            </Canvas>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding [Fan.Note], Source={x:Static loc:Localizer.Instance}}"
                                   Foreground="{StaticResource B.TextDim}" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
